# Server
PORT=8888
NODE_ENV=development
LOG_LEVEL=info

# Auth
# 使用强随机字符串，如：openssl rand -hex 32
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_generated_secret_here

# Database (MySQL)
# 本地开发配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bitcoin_mining_master
DB_USER=root
DB_PASSWORD=your_db_password_here

# Redis for Bull Queue
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# 如果Redis设置了密码，填写以下配置
# REDIS_PASSWORD=your_redis_password_here

# CORS Configuration
# 多个域名用逗号分隔
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# API Key for Mobile App
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_MOBILE=your_generated_api_key_here

# Google Play 服务账号（Android支付验证）
# GOOGLE_SERVICE_ACCOUNT_PATH=./src/config/google-service-account.json

# Apple Pay（iOS支付验证）
# APPLE_SHARED_SECRET=your_apple_shared_secret_here
