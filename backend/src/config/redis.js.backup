/**
 * Redis 客户端配置
 * 用于缓存用户等级、签到状态、广告计数等高频数据
 */

const Redis = require('ioredis');

class RedisClient {
  constructor() {
    this.client = null;
    this.isConnected = false;
  }

  /**
   * 初始化 Redis 连接
   */
  async connect() {
    try {
      this.client = new Redis({
        host: process.env.REDIS_HOST || '127.0.0.1',
        port: process.env.REDIS_PORT || 6379,
        password: process.env.REDIS_PASSWORD || undefined,
        db: process.env.REDIS_DB || 0,
        retryStrategy: (times) => {
          const delay = Math.min(times * 50, 2000);
          return delay;
        },
        maxRetriesPerRequest: 3
      });

      // 事件监听
      this.client.on('connect', () => {
        console.log('✅ Redis 连接成功');
        this.isConnected = true;
      });

      this.client.on('error', (err) => {
        console.error('❌ Redis 错误:', err);
        this.isConnected = false;
      });

      this.client.on('close', () => {
        console.log('⚠️ Redis 连接关闭');
        this.isConnected = false;
      });

      // 等待连接就绪
      await this.client.ping();
      
      return this.client;
    } catch (error) {
      console.error('❌ Redis 初始化失败:', error);
      throw error;
    }
  }

  /**
   * 关闭 Redis 连接
   */
  async disconnect() {
    if (this.client) {
      await this.client.quit();
      console.log('✅ Redis 连接已关闭');
    }
  }

  /**
   * 检查 Redis 是否已连接
   */
  isReady() {
    return this.isConnected && this.client && this.client.connected;
  }

  // ==================== 用户等级缓存 ====================

  /**
   * 缓存用户等级信息
   * Key: user:level:{user_id}
   */
  async cacheUserLevel(userId, levelData) {
    const key = `user:level:${userId}`;
    const data = {
      level: levelData.level,
      points: levelData.points,
      speed_multiplier: levelData.speedMultiplier,
      daily_bonus_active: levelData.dailyBonusActive ? '1' : '0',
      daily_bonus_expire: levelData.dailyBonusExpire || ''
    };
    await this.hmsetAsync(key, data);
    await this.expireAsync(key, 86400); // 24小时过期
    return true;
  }

  /**
   * 获取用户等级缓存
   */
  async getUserLevel(userId) {
    const key = `user:level:${userId}`;
    const data = await this.hgetallAsync(key);
    if (!data || Object.keys(data).length === 0) {
      return null;
    }
    return {
      level: parseInt(data.level),
      points: parseInt(data.points),
      speedMultiplier: parseFloat(data.speed_multiplier),
      dailyBonusActive: data.daily_bonus_active === '1',
      dailyBonusExpire: data.daily_bonus_expire || null
    };
  }

  /**
   * 删除用户等级缓存
   */
  async deleteUserLevel(userId) {
    const key = `user:level:${userId}`;
    await this.delAsync(key);
  }

  // ==================== 签到状态缓存 ====================

  /**
   * 缓存用户签到状态
   * Key: user:checkin:{user_id}
   */
  async cacheCheckInStatus(userId, checkInData) {
    const key = `user:checkin:${userId}`;
    const data = {
      last_date: checkInData.lastDate,
      consecutive_days: checkInData.consecutiveDays,
      bonus_active: checkInData.bonusActive ? '1' : '0',
      bonus_expire: checkInData.bonusExpire || ''
    };
    await this.hmsetAsync(key, data);
    await this.expireAsync(key, 172800); // 48小时过期
    return true;
  }

  /**
   * 获取用户签到状态缓存
   */
  async getCheckInStatus(userId) {
    const key = `user:checkin:${userId}`;
    const data = await this.hgetallAsync(key);
    if (!data || Object.keys(data).length === 0) {
      return null;
    }
    return {
      lastDate: data.last_date,
      consecutiveDays: parseInt(data.consecutive_days),
      bonusActive: data.bonus_active === '1',
      bonusExpire: data.bonus_expire || null
    };
  }

  // ==================== 广告观看计数 ====================

  /**
   * 增加今日广告观看次数
   * Key: user:ad:today:{user_id}
   */
  async incrementTodayAdCount(userId) {
    const key = `user:ad:today:${userId}`;
    const count = await this.incrAsync(key);
    
    // 第一次增加时设置过期时间(当天23:59:59)
    if (count === 1) {
      const now = new Date();
      const endOfDay = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59);
      const ttl = Math.floor((endOfDay - now) / 1000);
      await this.expireAsync(key, ttl);
    }
    
    return count;
  }

  /**
   * 获取今日广告观看次数
   */
  async getTodayAdCount(userId) {
    const key = `user:ad:today:${userId}`;
    const count = await this.getAsync(key);
    return count ? parseInt(count) : 0;
  }

  // ==================== 下级用户广告观看计数 ====================

  /**
   * 增加下级用户广告观看次数
   * Key: user:referral:ad:{referrer_id}:{referral_id}
   */
  async incrementReferralAdCount(referrerId, referralId) {
    const key = `user:referral:ad:${referrerId}:${referralId}`;
    const count = await this.incrAsync(key);
    await this.expireAsync(key, 2592000); // 30天过期
    return count;
  }

  /**
   * 获取下级用户广告观看次数
   */
  async getReferralAdCount(referrerId, referralId) {
    const key = `user:referral:ad:${referrerId}:${referralId}`;
    const count = await this.getAsync(key);
    return count ? parseInt(count) : 0;
  }

  // ==================== 邀请进度缓存 ====================

  /**
   * 缓存邀请进度
   * Key: user:invite:progress:{user_id}
   */
  async cacheInvitationProgress(userId, progressData) {
    const key = `user:invite:progress:${userId}`;
    const data = {
      total_count: progressData.totalCount,
      milestone_5_claimed: progressData.milestone5Claimed ? '1' : '0',
      milestone_10_claimed: progressData.milestone10Claimed ? '1' : '0',
      referral_ad_rewards: progressData.referralAdRewards || 0
    };
    await this.hmsetAsync(key, data);
    // 永不过期，手动更新
    return true;
  }

  /**
   * 获取邀请进度缓存
   */
  async getInvitationProgress(userId) {
    const key = `user:invite:progress:${userId}`;
    const data = await this.hgetallAsync(key);
    if (!data || Object.keys(data).length === 0) {
      return null;
    }
    return {
      totalCount: parseInt(data.total_count),
      milestone5Claimed: data.milestone_5_claimed === '1',
      milestone10Claimed: data.milestone_10_claimed === '1',
      referralAdRewards: parseInt(data.referral_ad_rewards || 0)
    };
  }

  // ==================== 每日签到加成激活用户集合 ====================

  /**
   * 添加到每日签到加成激活用户集合
   * Key: daily:bonus:active
   * Score: 过期时间戳
   */
  async addDailyBonusUser(userId, expireTimestamp) {
    const key = 'daily:bonus:active';
    await this.zaddAsync(key, expireTimestamp, userId);
    return true;
  }

  /**
   * 从每日签到加成激活用户集合中移除
   */
  async removeDailyBonusUser(userId) {
    const key = 'daily:bonus:active';
    await this.zremAsync(key, userId);
    return true;
  }

  /**
   * 清理过期的每日签到加成用户
   */
  async cleanExpiredDailyBonusUsers() {
    const key = 'daily:bonus:active';
    const now = Math.floor(Date.now() / 1000);
    const removed = await this.zremrangebyscoreAsync(key, '-inf', now);
    return removed;
  }

  /**
   * 检查用户是否在每日签到加成激活列表中
   */
  async isDailyBonusActive(userId) {
    const key = 'daily:bonus:active';
    const score = await this.client.zscore(key, userId);
    if (!score) return false;
    
    const now = Math.floor(Date.now() / 1000);
    return parseInt(score) > now;
  }

  // ==================== 通用缓存操作 ====================

  /**
   * 设置缓存 (带过期时间)
   */
  async set(key, value, ttl = null) {
    if (ttl) {
      await this.setAsync(key, value, 'EX', ttl);
    } else {
      await this.setAsync(key, value);
    }
    return true;
  }

  /**
   * 获取缓存
   */
  async get(key) {
    return await this.getAsync(key);
  }

  /**
   * 删除缓存
   */
  async delete(key) {
    await this.delAsync(key);
    return true;
  }

  /**
   * 批量删除缓存 (模糊匹配)
   */
  async deletePattern(pattern) {
    const keys = await this.keysAsync(pattern);
    if (keys && keys.length > 0) {
      await this.delAsync(...keys);
      return keys.length;
    }
    return 0;
  }
}

// 创建单例
const redisClient = new RedisClient();

module.exports = redisClient;
