# 本地开发环境变量模板
# 使用步骤：cp .env.dev.example .env.dev
# 然后填写真实的密码，绝对不要将 .env.dev 提交到 Git

# ===== MySQL =====
DEV_DB_ROOT_PASSWORD=change_me_root_password
DEV_DB_USER=bitcoin
DEV_DB_PASSWORD=change_me_db_password

# ===== Redis =====
DEV_REDIS_PASSWORD=change_me_redis_password

# ===== JWT =====
# 至少 32 位随机字符串，可用命令生成：openssl rand -hex 32
DEV_JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# ===== 管理员后台 =====
# 建议格式：大小写字母 + 数字 + 特殊字符，至少 12 位
ADMIN_PASSWORD=change_me_admin_password

# ===== Android Google Play =====
# Android 应用包名（必须与 build.gradle.kts applicationId 一致）
ANDROID_PACKAGE_NAME=com.cloudminingtool.bitcoin_mining_app

# ===== Apple In-App Purchase =====
# App Store Connect → App Information → App-Specific Shared Secret
APPLE_IAP_SHARED_SECRET=change_me_apple_shared_secret
# iOS 应用 Bundle ID（用于验证 Apple S2S 通知 bundleId，防伪造）
APPLE_BUNDLE_ID=com.cloudminingtool.bitcoin_mining_master
