# 本地开发环境变量示例
# 复制此文件为 .env.local 并根据实际情况修改

# API地址 - 根据后端实际运行地址修改
VITE_API_BASE_URL=http://localhost:8888/api
VITE_WS_URL=ws://localhost:8888

# 如果后端运行在其他端口，修改为对应端口
# VITE_API_BASE_URL=http://localhost:3000/api
# VITE_WS_URL=ws://localhost:3000

# 如果使用远程开发服务器
# VITE_API_BASE_URL=http://192.168.1.100:8888/api
# VITE_WS_URL=ws://192.168.1.100:8888
