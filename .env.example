# 环境变量示例文件
# 复制为 .env.development（开发）或 .env.production（生产）

# 服务器配置
NODE_ENV=development  # development | production
PORT=8888

# JWT密钥
JWT_SECRET=your_jwt_secret_key_here

# 数据库配置（开发环境）
DB_HOST=mysql  # Docker服务名
DB_PORT=3306
DB_NAME=bitcoin_mining_master
DB_USER=bitcoin
DB_PASSWORD=bitcoin_dev_123
DB_ROOT_PASSWORD=dev_password_123

# Redis配置（开发环境）
REDIS_HOST=redis  # Docker服务名
REDIS_PORT=6379
REDIS_PASSWORD=dev_redis_123

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# 日志级别
LOG_LEVEL=debug  # debug | info | warn | error
