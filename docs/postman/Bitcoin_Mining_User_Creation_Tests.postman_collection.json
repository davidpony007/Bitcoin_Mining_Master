		{
			"name": "❌ 错误测试 - 重复 user_id",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// 第一次调用应该成功（201）或失败（500，如果已存在）",
							"if (pm.response.code === 201) {",
							"    console.log('✅ 用户首次创建成功');",
							"} else if (pm.response.code === 500) {",
							"    pm.test('✅ 正确返回重复错误', function () {",
							"        const jsonData = pm.response.json();",
							"        pm.expect(jsonData.details).to.satisfy(msg => ",
							"            msg.includes('Duplicate') || msg.includes('unique')  || msg.includes('重复')",
							"        );",
							"        console.log('⚠️ 预期的重复错误:', jsonData.details);",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
