		{
			"name": "4️⃣ 创建用户 - Android 用户",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const timestamp = Date.now();",
							"pm.environment.set('timestamp', timestamp);",
							"",
							"// 模拟 Android 设备ID (32位)",
							"const androidId = 'a' + String(timestamp).padStart(31, '0').slice(-31);",
							"pm.environment.set('androidId', androidId);",
							"",
							"// 模拟 GAID (36位 UUID 格式)",
							"const gaid = `${timestamp.toString(16)}-a1b2-c3d4-e5f6-${String(timestamp).slice(-12)}`;",
							"pm.environment.set('gaid', gaid);",
							"",
							"console.log('📱 Android ID:', androidId);",
							"console.log('🔑 GAID:', gaid);"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('✅ Android 用户创建成功', function () {",
							"    pm.response.to.have.status(201);",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.data).to.have.property('android_id');",
							"    pm.expect(jsonData.data).to.have.property('gaid');",
							"    console.log('📱 Android 用户信息:', jsonData.data);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"user_id\": \"AND{{timestamp}}\",\n  \"email\": \"android_{{timestamp}}@gmail.com\",\n  \"android_id\": \"{{androidId}}\",\n  \"gaid\": \"{{gaid}}\",\n  \"register_ip\": \"1.2.3.4\",\n  \"country\": \"CN\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/users",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"users"
					]
				},
				"description": "创建 Android 平台用户\n\n**特点：**\n- 包含 android_id (Android 设备唯一标识)\n- 包含 gaid (Google Advertising ID)\n- 用于追踪 Android 用户行为"
			},
			"response": []
		},
		{
			"name": "5️⃣ 创建用户 - 带邀请码",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const timestamp = Date.now();",
							"pm.environment.set('timestamp', timestamp);",
							"",
							"// 生成邀请码 (13位: INV + 10位数字)",
							"const inviteCode = 'INV' + String(Math.floor(Math.random() * 10000000000)).padStart(10, '0');",
							"pm.environment.set('inviteCode', inviteCode);",
							"",
							"console.log('🎁 邀请码:', inviteCode);"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('✅ 带邀请码用户创建成功', function () {",
							"    pm.response.to.have.status(201);",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.data.invitation_code).to.not.be.null;",
							"    console.log('🎁 邀请码已保存:', jsonData.data.invitation_code);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"user_id\": \"INV{{timestamp}}\",\n  \"invitation_code\": \"{{inviteCode}}\",\n  \"email\": \"invite_{{timestamp}}@example.com\",\n  \"country\": \"CN\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/users",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"users"
					]
				},
				"description": "创建带邀请码的用户\n\n**用途：**\n- 测试邀请系统\n- invitation_code 用于追踪用户来源\n- 可用于返佣系统"
			},
			"response": []
		},
