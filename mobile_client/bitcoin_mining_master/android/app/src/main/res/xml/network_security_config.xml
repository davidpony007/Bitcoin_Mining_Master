<?xml version="1.0" encoding="utf-8"?>
<!--
  网络安全配置
  - 生产域名 (smartearningtool.top) 仅允许 HTTPS，由系统默认策略保障
  - 仅对本地开发地址允许 HTTP 明文流量（localhost / Android 模拟器 10.0.2.2）
  - 禁止对其他所有域使用 HTTP 明文
-->
<network-security-config>
    <!-- 生产环境：仅 HTTPS（系统默认，无需额外配置） -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">smartearningtool.top</domain>
    </domain-config>

    <!-- 本地开发：允许 HTTP（仅 localhost 和 Android 模拟器回环地址） -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!-- 全局默认：禁止明文 HTTP -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
